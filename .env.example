# Environment variables for DMX Crawler

# Database configuration
DB_URL=sqlite:///dmx.sqlite
# DB_URL=postgresql+psycopg://user:password@localhost/dmx_crawler

# Crawler settings
DMX_BASE_URL=https://www.dienmayxanh.com/
DMX_USER_AGENT=DMX-Crawler/1.0
DMX_CONCURRENCY=3
DMX_DELAY_MIN=1
DMX_DELAY_MAX=3
DMX_MAX_PRODUCTS=0
DMX_RESPECT_ROBOTS=true

# Playwright settings
PLAYWRIGHT_BROWSER=chromium
PLAYWRIGHT_HEADLESS=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=dmx_crawler.log

# Export settings
EXPORT_DIR=./exports/