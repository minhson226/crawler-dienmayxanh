# Environment Variables
DB_URL=sqlite:///dmx.sqlite
# For PostgreSQL: postgresql+psycopg://user:pass@host/db

# Crawler settings
BASE_URL=https://www.dienmayxanh.com
USER_AGENT=DMX-Crawler/1.0 (Educational Purpose)
CONCURRENCY=3
DELAY_MIN=1
DELAY_MAX=3
MAX_PRODUCTS=1000
RESPECT_ROBOTS=true

# Logging
LOG_LEVEL=INFO
LOG_FILE=crawler.log

# Cache settings
USE_CACHE=true
CACHE_EXPIRE=3600

# Playwright settings
USE_PLAYWRIGHT=auto
HEADLESS=true
TIMEOUT=30000